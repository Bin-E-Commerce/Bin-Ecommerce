# ============================================================
# Bin E-Commerce — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bin_ecommerce
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=bin_ecommerce

# ── MongoDB ──────────────────────────────────────────────────
# Docker local: mongodb://root:changeme_mongo@localhost:27017/bin_ecommerce?authSource=admin
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme_mongo
MONGODB_URI=mongodb://root:changeme_mongo@localhost:27017/bin_ecommerce?authSource=admin

# ── Redis (OTP challenges) ────────────────────────────────────
# Docker local: no password by default
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kafka ────────────────────────────────────────────────────
# Chưa tích hợp vào code — dùng khi implement Kafka events
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=bin-ecommerce
KAFKA_GROUP_ID_PREFIX=bin-ecommerce

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bin-ecommerce

# Client ROPC — dùng để đổi username/password lấy token (auth-service)
KEYCLOAK_CLIENT_ID=auth-service
KEYCLOAK_CLIENT_SECRET=changeme_keycloak_secret

# Client Admin API — dùng client_credentials để gọi Keycloak Admin REST API
KEYCLOAK_ADMIN_CLIENT_ID=auth-service-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=changeme_admin_secret

# Client PKCE — dùng cho frontend (social login redirect)
KEYCLOAK_WEB_CLIENT_ID=web-client

# Keycloak Admin Console login (dùng trong docker-compose.infra.yml)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_admin

# ── Frontend URL (OAuth callback redirect) ───────────────────
FRONTEND_URL=http://localhost:5173

# ── Services — internal URLs (Docker network) ────────────────
AUTH_SERVICE_URL=http://auth-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
CART_SERVICE_URL=http://cart-service:3003
ORDER_SERVICE_URL=http://order-service:3004
INVENTORY_SERVICE_URL=http://inventory-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006
SHIPPING_SERVICE_URL=http://shipping-service:3007
PROMOTION_SERVICE_URL=http://promotion-service:3008
RETURN_SERVICE_URL=http://return-service:3009

# ── SMTP (OTP email — production only, dev dùng console log) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@binecommerce.com

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana
